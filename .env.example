# Copy to .env and fill in values. Do not commit .env (it is gitignored).
#
# Used by profiles/profiles.yml for BigQuery (dbt-bigquery, service-account auth).
# Local: export these or run `set -a && source .env && set +a` before dbt commands.
# Docker: pass with -e or --env-file .env (see README).

# GCP project where dbt creates models (required)
DBT_BQ_PROJECT=the-data-strategist

# BigQuery dataset for built relations (optional; default: the_most_python)
DBT_BQ_DATASET=the_most_python

# Absolute path to a GCP service account JSON key with BigQuery access (required)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Directory containing profiles.yml (optional for local dev; Docker sets this to /app/profiles)
DBT_PROFILES_DIR=./profiles
